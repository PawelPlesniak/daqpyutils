repos:
  - repo: local
    hooks:
      - id: ruff
        name: Ruff Linter
        entry: ruff check --fix --exit-non-zero-on-fix
        language: system
        types: [python]

      - id: black
        name: Black Formatter
        entry: black --check
        language: system
        types: [python]

      - id: isort
        name: isort Import Sorter
        entry: isort
        language: system
        types: [python]

      - id: pytest
        name: Run tests with pytest
        entry: pytest -v tests/ --tb=short --disable-warnings
        language: system
        types: [python]
        pass_filenames: false
